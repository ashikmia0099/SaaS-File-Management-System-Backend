// this model create for admin can create subscription package 

model SubscriptionPackage {
    id               String   @id @default(uuid())
    PackageName      String   @unique
    MaxFolders       Int
    MaxNestingFolder Int
    AllowedFileTypes String[]
    MaxFileSizeMB    Int
    TotalFileLimit   Int
    FilePerFolder    Int
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
    selectedUser UserSelectedPackage[]
}
